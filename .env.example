SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_SOCKET_MODE=true
SLACK_APP_TOKEN=xapp-your-app-level-token

# 공통 GMG 공지 채널 ID입니다. 채널 이름이 아니라 C로 시작하는 Slack channel ID를 넣습니다.
GMG_ANNOUNCEMENT_CHANNEL_ID=C0123456789

# Slack datepicker/timepicker 값은 timezone 정보를 주지 않으므로 한국 워크스페이스 기본값으로 +09:00을 사용합니다.
GMG_TIMEZONE_OFFSET=+09:00

# 프로세스 재시작 후에도 모임과 리마인더를 복구하기 위한 로컬 JSON 저장소입니다.
GMG_DATA_FILE=.gmg/meetings.json

# HTTP mode를 쓸 때만 의미가 있습니다. Socket Mode에서는 app.start()가 포트를 열지 않습니다.
PORT=3000
